rCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0},{"filePath":"78","messages":"79","errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0},{"filePath":"80","messages":"81","errorCount":0,"fatalErrorCount":0,"warningCount":1,"fixableErrorCount":0,"fixableWarningCount":0,"source":"82"},{"filePath":"83","messages":"84","errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0},{"filePath":"85","messages":"86","errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0},{"filePath":"87","messages":"88","errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0},{"filePath":"89","messages":"90","errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0},{"filePath":"91","messages":"92","errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0},{"filePath":"93","messages":"94","errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0},{"filePath":"95","messages":"96","errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0},{"filePath":"97","messages":"98","errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0},"D:\\University (Sem 9+)\\SEM 12\\IGB400\\Assignment 1\\igb400-portfolio\\pages\\404.tsx",[],"D:\\University (Sem 9+)\\SEM 12\\IGB400\\Assignment 1\\igb400-portfolio\\pages\\500.tsx",[],"D:\\University (Sem 9+)\\SEM 12\\IGB400\\Assignment 1\\igb400-portfolio\\pages\\contact.tsx",[],"D:\\University (Sem 9+)\\SEM 12\\IGB400\\Assignment 1\\igb400-portfolio\\pages\\index.tsx",[],"D:\\University (Sem 9+)\\SEM 12\\IGB400\\Assignment 1\\igb400-portfolio\\pages\\overview.tsx",[],"D:\\University (Sem 9+)\\SEM 12\\IGB400\\Assignment 1\\igb400-portfolio\\pages\\Projects\\CAB201.tsx",[],"D:\\University (Sem 9+)\\SEM 12\\IGB400\\Assignment 1\\igb400-portfolio\\pages\\Projects\\CAB301.tsx",[],"D:\\University (Sem 9+)\\SEM 12\\IGB400\\Assignment 1\\igb400-portfolio\\pages\\Projects\\CAB401.tsx",[],"D:\\University (Sem 9+)\\SEM 12\\IGB400\\Assignment 1\\igb400-portfolio\\pages\\Projects\\IFB399.tsx",[],"D:\\University (Sem 9+)\\SEM 12\\IGB400\\Assignment 1\\igb400-portfolio\\pages\\Projects\\IGB200.tsx",[],"D:\\University (Sem 9+)\\SEM 12\\IGB400\\Assignment 1\\igb400-portfolio\\pages\\Projects\\IGB383.tsx",[],"D:\\University (Sem 9+)\\SEM 12\\IGB400\\Assignment 1\\igb400-portfolio\\pages\\Projects\\IGB388.tsx",[],"D:\\University (Sem 9+)\\SEM 12\\IGB400\\Assignment 1\\igb400-portfolio\\pages\\projects.tsx",[],"D:\\University (Sem 9+)\\SEM 12\\IGB400\\Assignment 1\\igb400-portfolio\\pages\\_app.tsx",[],"D:\\University (Sem 9+)\\SEM 12\\IGB400\\Assignment 1\\igb400-portfolio\\components\\Content\\Contact.tsx",[],"D:\\University (Sem 9+)\\SEM 12\\IGB400\\Assignment 1\\igb400-portfolio\\components\\Content\\Overview.tsx",["99"],"import React, { useEffect, useState } from \"react\";\nimport Image from \"next/image\";\n\nconst images = [\n  \"/images/Brisbane/1.jpg\",\n  \"/images/Brisbane/2.jpg\",\n  \"/images/Brisbane/3.jpg\",\n  \"/images/Brisbane/4.jpg\",\n  \"/images/Brisbane/5.jpg\",\n  \"/images/Brisbane/6.jpg\",\n];\n\nexport default function Overview() {\n  const [count, setCount] = useState(0);\n\n  useEffect(() => {\n    const timerId = setInterval(() => {\n      setCount((count) => count + 1);\n    }, 500);\n\n    return () => clearInterval(timerId);\n  }, []);\n\n  const image = images[count % images.length];\n\n  return (\n    <>\n      <div className=\"mx-auto mb-16 flex max-w-2xl flex-col items-start\">\n        <div className=\"mt-12 p-4 md:p-4 lg:p-0\">\n          <h1 className=\"Inter-Medium text-2xl tracking-tight text-white md:text-3xl\">\n            Overview\n          </h1>\n        </div>\n        <h2 className=\"text-md Inter-Medium relative mb-6 inline pr-10 pt-0 pl-4 text-[#ddd] sm:text-lg md:pr-0 md:pt-0 md:pl-4 lg:pt-5 lg:pl-0\">\n          I\\'m a software developer in{\" \"}\n          <div className=\"relative inline\">\n            <div className=\"show Inter-SemiBold inline text-white\">\n              Brisbane\n            </div>\n            <div className=\"hide z-10 ml-[25rem] hidden w-56 \">\n              <img src={image} alt=\"Brisbane city\" className=\"rounded-lg\" />\n            </div>\n          </div>\n          {\" \"}and have worked in front-end, back-end, game development, automated testing and more.\n        </h2>\n\n        {/* random shit about me */}\n        <div className=\"mb-4 flex flex-col gap-0 lg:grid lg:grid-cols-2 lg:gap-6\">\n          <Image src={`/images/Profile Picture.jpg`}\n                  alt={\"gaming\"}\n                  width={2268}\n                  height={2424}\n                />\n          {/* TODO: cool selfie with some bs about my uni life */}\n          <p className=\"Inter-Medium text-base text-[#ddd] lg:pt-5\">\n            My focus is quite broad and revolves around using multimedia as an artform.\n            <br/>\n            <br/>\n            By combining visual media and programming with some niches (such as kinetic typography), I believe a unique set of projects can be made and shared.\n            <br/>\n            Inspiration comes from various sources; music, content creators, friends, games, and just weird corners of the internet at times.\n          </p>\n        </div>\n\n        {/* Project Pitch thing */}\n        <div className=\"mt-12 p-4 md:p-4 lg:p-0\">\n          <h1 className=\"Inter-Medium text-2xl tracking-tight text-white md:text-3xl\">\n            Project Proposal\n          </h1>\n        </div>\n        <p className=\"Inter-Medium text-base text-[#ddd] lg:pt-5\">\n          Mobile gaming takes an enormous percentage of the gaming demographic, 81% of north americans on the platform engage in mobile gaming, which is also the fastest growing gaming platform in EU (Google, 2021).\n          A lot of people play mobile games, and a lot of mobile games come riddled with ads.\n        </p>\n        <p className=\"Inter-Medium text-base text-[#ddd] lg:pt-5\">\n          I hope to mitigate this problem by introducing a simple collection of games without any monetization. Minesweeper and Sodoku are two prime examples of games that I personally feel shouldn\\'t have any advertising involved.\n          <br/>\n          According to MistPlay (2023), video ads within the mobile market is the most popular form of ad revenue shortly followed by perodic forced ads between rounds, levels, etc.\n          By removing ads entirely and documenting my progress on various platforms, I believe it\\'s possible to gain publicity within the mobile game development ecosystem.\n        </p>\n        <p className=\"Inter-Medium text-base text-[#ddd] lg:pt-5\">\n        A minimalistic minesweeper and sodoku game will demonstrate core skills to a job provider while delivering a positive user experience for those who choose to download.\n        </p>\n        <br/>\n        <p className=\"Inter-Medium text-base text-[#ddd] lg:pt-5\">\n          Google, (2021). <i>Beyond 2021: Where does gaming go next?</i>. Google for Games <u><a href=\"https://games.withgoogle.com/reports/beyondreport/\">https://games.withgoogle.com/reports/beyondreport/</a></u>\n          <br/>\n          MistPlay, (2023). <i>The long game: How to reduce churn and retain mobile gamers</i>. MistPlay <u><a href=\"https://www.mistplay.com/resources/mobile-game-churn-retention-strategies\">https://www.mistplay.com/resources/mobile-game-churn-retention-strategies</a></u>\n        </p>\n      </div>\n    </>\n  );\n}\n","D:\\University (Sem 9+)\\SEM 12\\IGB400\\Assignment 1\\igb400-portfolio\\components\\Content\\Projects.tsx",[],"D:\\University (Sem 9+)\\SEM 12\\IGB400\\Assignment 1\\igb400-portfolio\\components\\Footer.tsx",[],"D:\\University (Sem 9+)\\SEM 12\\IGB400\\Assignment 1\\igb400-portfolio\\components\\Header.tsx",[],"D:\\University (Sem 9+)\\SEM 12\\IGB400\\Assignment 1\\igb400-portfolio\\components\\Home\\Layout.tsx",[],"D:\\University (Sem 9+)\\SEM 12\\IGB400\\Assignment 1\\igb400-portfolio\\components\\LayoutGA.tsx",[],"D:\\University (Sem 9+)\\SEM 12\\IGB400\\Assignment 1\\igb400-portfolio\\components\\Skills\\Skills.tsx",[],"D:\\University (Sem 9+)\\SEM 12\\IGB400\\Assignment 1\\igb400-portfolio\\components\\Work\\Recent.tsx",[],"D:\\University (Sem 9+)\\SEM 12\\IGB400\\Assignment 1\\igb400-portfolio\\components\\Work\\Work.tsx",[],{"ruleId":"100","severity":1,"message":"101","line":41,"column":15,"nodeType":"102","endLine":41,"endColumn":77},"@next/next/no-img-element","Do not use <img>. Use Image from 'next/image' instead. See https://nextjs.org/docs/messages/no-img-element.","JSXOpeningElement"]